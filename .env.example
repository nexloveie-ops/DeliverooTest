PORT=8080
NODE_ENV=development

# Deliveroo API settings
DELIVEROO_BASE_URL=https://api-sandbox.developers.deliveroo.com
DELIVEROO_AUTH_BASE_URL=https://auth-sandbox.developers.deliveroo.com
DELIVEROO_CLIENT_ID=
DELIVEROO_CLIENT_SECRET=
DELIVEROO_LOCATION_ID=100121
# Optional overrides (auto-discovered when empty)
DELIVEROO_BRAND_ID=
DELIVEROO_SITE_ID=
DELIVEROO_MENU_ID=

# Webhook HMAC secret (X-Deliveroo-Hmac-Sha256). Leave empty to skip verification in test.
# See https://api-docs.deliveroo.com/docs/securing-webhooks
DELIVEROO_WEBHOOK_SECRET=

# Your own system endpoint for normalized events
FORWARD_TARGET_URL=
FORWARD_AUTH_TOKEN=
